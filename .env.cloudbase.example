# Copy this file to .env.cloudbase before using CloudBase CLI:
#   cp .env.cloudbase.example .env.cloudbase
#
# Do not commit .env.cloudbase. Fill in real secrets in the copied file.

CLOUDBASE_ENV_ID=replace-with-your-cloudbase-env-id
CLOUDBASE_API_BASE_URL=/api
CLOUDBASE_CONFIGURE_API_ROUTE=True
CLOUDBASE_REMOVE_LEGACY_API_WILDCARD_ROUTE=True
# Optional. Leave empty to let scripts/cloudbase-deploy.sh parse it from hosting deploy output.
CLOUDBASE_FRONTEND_DOMAIN=

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
TIME_ZONE=Asia/Shanghai
LOG_LEVEL=INFO
PORT=80

# For the first CloudBase run, "*" avoids 400 Bad Request while you confirm
# the generated CloudBase domain. Replace it with your real domain later.
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://*.tcloudbaseapp.com,https://*.ap-shanghai.tcb.qcloud.la,https://your-domain.example.com
CORS_ALLOWED_ORIGINS=https://your-domain.example.com
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_ALL_ORIGINS=False

# CloudBase SQL is usually MySQL-compatible. You can still use PostgreSQL by
# changing DB_ENGINE and the corresponding POSTGRES_* variables.
DB_ENGINE=mysql
MYSQL_DATABASE=lesson_review
MYSQL_HOST=replace-with-cloudbase-sql-host
MYSQL_PORT=3306
MYSQL_USER=replace-with-cloudbase-sql-user
MYSQL_PASSWORD=replace-with-cloudbase-sql-password
# Set this to True only when the DB user is allowed to create databases.
MYSQL_CREATE_DATABASE=False

# If you use an external PostgreSQL service instead, switch to:
# DB_ENGINE=postgres
# POSTGRES_DB=lesson_review
# POSTGRES_HOST=replace-with-postgres-host
# POSTGRES_PORT=5432
# POSTGRES_USER=replace-with-postgres-user
# POSTGRES_PASSWORD=replace-with-postgres-password

# Use synchronous parsing on CloudBase first. It avoids a separate Redis/Worker
# deployment and is the simplest way to get the system online.
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

MAX_UPLOAD_SIZE_MB=20
SERVE_MEDIA_FILES=True
MEDIA_ROOT=/app/backend/media
MEDIA_URL=/api/media/
MEDIA_STORAGE_BACKEND=apps.core.storage.DatabaseMediaStorage
SERVE_STATIC_FILES=True
STATIC_URL=/api/static/
X_FRAME_OPTIONS=SAMEORIGIN
DB_CONN_MAX_AGE=60

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password

VITE_API_BASE_URL=/api
