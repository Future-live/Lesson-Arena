{
  "version": "2.0",
  "envId": "{{env.CLOUDBASE_ENV_ID}}",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "framework": {
    "name": "lesson-review",
    "plugins": {
      "frontend": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "installCommand": "cd frontend && npm ci",
          "buildCommand": "cd frontend && VITE_API_BASE_URL={{env.CLOUDBASE_API_BASE_URL}} npm run build",
          "outputPath": "frontend/dist",
          "cloudPath": "/",
          "ignore": [
            ".git",
            ".github",
            "node_modules",
            "frontend/node_modules",
            "cloudbaserc.js"
          ]
        }
      },
      "backend": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "mode": "low-cost",
          "cpu": 1,
          "mem": 2,
          "minNum": 0,
          "maxNum": 2,
          "serviceName": "lesson-review-api",
          "servicePath": "/api",
          "localPath": "./",
          "uploadType": "package",
          "containerPort": 80,
          "dockerfilePath": "./Dockerfile.cloudbase",
          "buildDir": "./",
          "initialDelaySeconds": 60,
          "envVariables": {
            "PORT": "80",
            "DEBUG": "{{env.DEBUG}}",
            "SECRET_KEY": "{{env.SECRET_KEY}}",
            "TIME_ZONE": "{{env.TIME_ZONE}}",
            "LOG_LEVEL": "{{env.LOG_LEVEL}}",
            "ALLOWED_HOSTS": "{{env.ALLOWED_HOSTS}}",
            "CSRF_TRUSTED_ORIGINS": "{{env.CSRF_TRUSTED_ORIGINS}}",
            "CORS_ALLOWED_ORIGINS": "{{env.CORS_ALLOWED_ORIGINS}}",
            "CORS_ALLOWED_ORIGIN_REGEXES": "",
            "CORS_ALLOW_ALL_ORIGINS": "{{env.CORS_ALLOW_ALL_ORIGINS}}",
            "DB_ENGINE": "{{env.DB_ENGINE}}",
            "MYSQL_DATABASE": "{{env.MYSQL_DATABASE}}",
            "MYSQL_HOST": "{{env.MYSQL_HOST}}",
            "MYSQL_PORT": "{{env.MYSQL_PORT}}",
            "MYSQL_USER": "{{env.MYSQL_USER}}",
            "MYSQL_PASSWORD": "{{env.MYSQL_PASSWORD}}",
            "MYSQL_CREATE_DATABASE": "{{env.MYSQL_CREATE_DATABASE}}",
            "CELERY_TASK_ALWAYS_EAGER": "{{env.CELERY_TASK_ALWAYS_EAGER}}",
            "CELERY_BROKER_URL": "{{env.CELERY_BROKER_URL}}",
            "CELERY_RESULT_BACKEND": "{{env.CELERY_RESULT_BACKEND}}",
            "MAX_UPLOAD_SIZE_MB": "{{env.MAX_UPLOAD_SIZE_MB}}",
            "SERVE_MEDIA_FILES": "{{env.SERVE_MEDIA_FILES}}",
            "MEDIA_ROOT": "{{env.MEDIA_ROOT}}",
            "MEDIA_URL": "{{env.MEDIA_URL}}",
            "MEDIA_STORAGE_BACKEND": "{{env.MEDIA_STORAGE_BACKEND}}",
            "SERVE_STATIC_FILES": "{{env.SERVE_STATIC_FILES}}",
            "STATIC_URL": "{{env.STATIC_URL}}",
            "X_FRAME_OPTIONS": "{{env.X_FRAME_OPTIONS}}",
            "DB_CONN_MAX_AGE": "{{env.DB_CONN_MAX_AGE}}",
            "GUNICORN_WORKERS": "2",
            "GUNICORN_TIMEOUT": "180",
            "DJANGO_SUPERUSER_USERNAME": "{{env.DJANGO_SUPERUSER_USERNAME}}",
            "DJANGO_SUPERUSER_EMAIL": "{{env.DJANGO_SUPERUSER_EMAIL}}",
            "DJANGO_SUPERUSER_PASSWORD": "{{env.DJANGO_SUPERUSER_PASSWORD}}"
          }
        }
      }
    }
  }
}
