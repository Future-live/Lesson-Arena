DEBUG=True
SECRET_KEY=replace-with-a-secure-random-string
TIME_ZONE=Asia/Shanghai
LOG_LEVEL=INFO

DB_ENGINE=postgres
POSTGRES_DB=lesson_review
POSTGRES_USER=lesson_review
POSTGRES_PASSWORD=lesson_review
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False

ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGIN_REGEXES=^http://127\.0\.0\.1:\d+$,^http://localhost:\d+$
CORS_ALLOW_ALL_ORIGINS=False
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1,http://localhost

MAX_UPLOAD_SIZE_MB=20
SERVE_MEDIA_FILES=True
MEDIA_URL=/media/
MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
SERVE_STATIC_FILES=False
STATIC_URL=/static/
X_FRAME_OPTIONS=SAMEORIGIN
DB_CONN_MAX_AGE=60

DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
